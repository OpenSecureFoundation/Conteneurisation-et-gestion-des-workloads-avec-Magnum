# ============================================================
# Configuration OpenStack - MagnumDash
# Copiez ce fichier en .env et remplissez vos valeurs
# ============================================================

OS_AUTH_URL=http://<CONTROLLER_IP>:5000/v3
OS_PROJECT_NAME=admin
OS_USERNAME=admin
OS_PASSWORD=<YOUR_PASSWORD>
OS_USER_DOMAIN_NAME=Default
OS_PROJECT_DOMAIN_NAME=Default
OS_REGION_NAME=RegionOne
OS_IDENTITY_API_VERSION=3

# Flask config
FLASK_SECRET_KEY=magnum-dash-secret-change-in-production
FLASK_DEBUG=False
FLASK_HOST=0.0.0.0
FLASK_PORT=8080
